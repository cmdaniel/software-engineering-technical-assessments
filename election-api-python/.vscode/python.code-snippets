  "801-Validation | Dataclass | Field Validators": {
    "scope": "python",
    "prefix": [
      "group-validation",
      "template-validator",
      "dataclass-validator",
      "field-validator",
      "validatable-dataclass",
      "validator-decorator"
    ],
    "description": "[Template][Validation] Validatable base class with @validator decorator hooks for dataclass fields.",
    "body": [
      "from __future__ import annotations",
      "",
      "from dataclasses import dataclass",
      "from typing import Any, Callable, Final, Iterator",
      "",
      "VALIDATOR_ATTR: Final[str] = \"_validate_field\"",
      "",
      "",
      "def ${1:validator}(field_name: str) -> Callable[[Callable[..., Any]], Callable[..., Any]]:",
      "    def decorator(func: Callable[..., Any]) -> Callable[..., Any]:",
      "        setattr(func, VALIDATOR_ATTR, field_name)",
      "        return func",
      "",
      "    return decorator",
      "",
      "",
      "class ${2:Validatable}:",
      "    \"\"\"Base class for dataclasses with field-level validators.",
      "",
      "    Validators are instance methods decorated with @validator(\"<field_name>\").",
      "    Each takes the current value and returns the (possibly transformed) value.",
      "    \"\"\"",
      "",
      "    def __post_init__(self) -> None:",
      "        for field_name, validate in self._validators():",
      "            if not hasattr(self, field_name):",
      "                raise AttributeError(",
      "                    f\"{self.__class__.__name__} has validator for unknown field {field_name!r}\"",
      "                )",
      "",
      "            value = getattr(self, field_name)",
      "            new_value = validate(value)",
      "            object.__setattr__(self, field_name, new_value)",
      "",
      "    def _validators(self) -> Iterator[tuple[str, Callable[[Any], Any]]]:",
      "        for attr_name in dir(self):",
      "            method = getattr(self, attr_name)",
      "            if not callable(method):",
      "                continue",
