    "body": [
      "# Pattern: Strategy — switch algorithms without changing context code.",
      "from __future__ import annotations",
      "",
      "from dataclasses import dataclass",
      "from typing import Generic, Protocol, TypeVar",
      "",
      "InT = TypeVar(\"InT\", contravariant=True)",
      "OutT = TypeVar(\"OutT\", covariant=True)",
      "",
      "",
      "class Strategy(Protocol[InT, OutT]):",
      "    def __call__(self, value: InT) -> OutT: ...",
      "",
      "",
      "@dataclass(slots=True)",
      "class Context(Generic[InT, OutT]):",
      "    strategy: Strategy[InT, OutT]",
      "",
      "    def execute(self, value: InT) -> OutT:",
      "        return self.strategy(value)",
      "",
      "",
      "def ${1:double}(value: int) -> int:",
      "    return value * 2",
      "",
      "",
      "ctx = Context[int, int](strategy=${1:double})",
