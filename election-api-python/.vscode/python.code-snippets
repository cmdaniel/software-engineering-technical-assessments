      "protocol-wrapper"
    ],
    "description": "[Template][DesignPattern] Adapter: wrap legacy/third-party APIs behind a Protocol to keep domain code decoupled.",
    "body": [
      "# Pattern: Adapter — convert an incompatible API into the interface your app expects.",
      "from __future__ import annotations",
      "",
      "from dataclasses import dataclass",
      "from typing import Protocol",
      "",
      "",
      "class Notifier(Protocol):",
      "    \"\"\"Target interface your domain code depends on.\"\"\"",
      "",
      "    def send(self, message: str) -> None: ...",
      "",
      "",
      "class ${1:LegacyClient}:",
      "    \"\"\"Existing dependency with a different method name/shape.\"\"\"",
      "",
      "    def publish(self, payload: str) -> None:",
      "        print(payload)",
      "",
      "",
      "@dataclass(slots=True)",
      "class ${2:LegacyNotifierAdapter}:",
      "    \"\"\"Maps Notifier.send → LegacyClient.publish.\"\"\"",
      "",
      "    client: ${1:LegacyClient}",
      "",
      "    def send(self, message: str) -> None:",
      "        self.client.publish(message)",
      "",
      "",
      "def notify(notifier: Notifier, message: str) -> None:",
      "    notifier.send(message)",
      "",
      "",
      "notify(${2:LegacyNotifierAdapter}(client=${1:LegacyClient}()), ${3:\"hello\"})"
    ]
  },
