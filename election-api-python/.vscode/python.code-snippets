  "107-DesignPattern | Policy Registry | Strategy + Factory + Registry": {
    "scope": "python",
    "prefix": [
      "group-designpattern",
      "template-policy",
      "dp-policy",
      "policy-registry",
      "policy-factory",
      "versioned-policy",
      "strategy-abc"
    ],
    "description": "[Template][DesignPattern] Policy Registry: ABC strategy + factory + registry for versioned policies.",
    "body": [
      "# Pattern: Policy Registry — versioned strategies with singleton registry.",
      "from __future__ import annotations",
      "",
      "from abc import ABC, abstractmethod",
      "from dataclasses import dataclass, field",
      "",
      "",
      "class ${1:PolicyStrategy}(ABC):",
      "    @abstractmethod",
      "    def evaluate(self, data: dict) -> bool:",
      "        raise NotImplementedError",
      "",
      "",
      "class ${2:PolicyV1}(${1:PolicyStrategy}):",
      "    def evaluate(self, data: dict) -> bool:",
      "        return data.get(\"${3:age}\", 0) >= ${4:18}",
      "",
      "",
      "class ${5:PolicyV2}(${1:PolicyStrategy}):",
      "    def evaluate(self, data: dict) -> bool:",
      "        return data.get(\"${3:age}\", 0) >= ${6:21}",
      "",
      "",
      "class ${7:PolicyFactory}:",
      "    @staticmethod",
      "    def create(version: str) -> ${1:PolicyStrategy}:",
      "        if version == \"${8:v1}\":",
      "            return ${2:PolicyV1}()",
      "        if version == \"${9:v2}\":",
      "            return ${5:PolicyV2}()",
      "        raise ValueError(f\"Unknown policy version: {version}\")",
      "",
      "",
      "@dataclass(slots=True)",
      "class ${10:PolicyRegistry}:",
      "    \"\"\"Singleton registry — each version is a separate strategy instance.\"\"\"",
      "",
      "    _policies: dict[str, ${1:PolicyStrategy}] = field(default_factory=dict)",
      "",
      "    def register(self, name: str, policy: ${1:PolicyStrategy}) -> None:",
      "        self._policies[name] = policy",
      "",
      "    def get(self, name: str) -> ${1:PolicyStrategy}:",
      "        return self._policies[name]",
      "",
      "",
      "@dataclass(slots=True)",
      "class ${11:PricingService}:",
      "    policy: ${1:PolicyStrategy}",
      "",
      "    def process(self, data: dict) -> str:",
      "        return \"approved\" if self.policy.evaluate(data) else \"rejected\"",
      "",
      "",
      "registry = ${10:PolicyRegistry}()",
      "registry.register(\"${8:v1}\", ${7:PolicyFactory}.create(\"${8:v1}\"))",
      "service = ${11:PricingService}(policy=registry.get(\"${8:v1}\"))"
    ]
  },
